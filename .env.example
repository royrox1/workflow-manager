# Workflow Manager - Default API Keys
# Rename this file to .env.local and add your keys here. 
# Vite will automatically pick these up and use them as the default if a user
# hasn't configured a specific key in the Settings UI.

# -------------------------------------------------------------
# LLM Provider Configuration (Anthropic / OpenAI / Ollama)
# -------------------------------------------------------------

# 'anthropic' | 'openai' | 'ollama'
# VITE_LLM_PROVIDER="anthropic"

# VITE_LLM_API_KEY="sk-ant-..."

# Default models:
# Anthropic: claude-3-5-sonnet-20241022
# OpenAI:    gpt-4o
# Ollama:    llama3.2
# VITE_LLM_MODEL="claude-3-5-sonnet-20241022"

# Default Base URLs:
# Anthropic: https://api.anthropic.com/v1
# OpenAI:    https://api.openai.com/v1
# Ollama:    http://localhost:11434/v1
# VITE_LLM_BASE_URL="https://api.anthropic.com/v1"
